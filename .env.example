# Claude Telegram Bot - Environment Configuration

# ==============================================================================
# REQUIRED
# ==============================================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram user IDs allowed to use the bot.
# Find your ID: message @userinfobot on Telegram. Include guest IDs here too.
TELEGRAM_ALLOWED_USERS=123456789

# Optional: comma-separated IDs for new guest users (vault at /opt/vault/{userId}/).
# If unset, defaults to a hardcoded list including all known testers.
# NEW_GUEST_USERS=403360614,893951298

# ==============================================================================
# SUBSCRIPTION GATE (optional)
# ==============================================================================
# If REQUIRED_CHANNEL_ID is set, every non-owner user must be a member of that
# channel before the bot will respond. The bot must be added as administrator
# of the channel for getChatMember to work.
#   - Public channels:  use @username (e.g. @my_channel)
#   - Private channels: use the numeric chat id (e.g. -1001234567890)
# REQUIRED_CHANNEL_URL is the public link shown to users in the gate message.
# Leave both empty to disable the gate.
# REQUIRED_CHANNEL_ID=@my_channel
# REQUIRED_CHANNEL_URL=https://t.me/my_channel

# Channel id for owner alerts (CPU spikes, OOM, daemon crashloops, egress
# throttle). Add the bot as admin to the channel — on add the bot logs the
# chat_id and DMs it to the owner. If unset, alerts fall back to owner DM.
# OWNER_PROBLEM_CHANNEL_ID=-1001234567890

# ==============================================================================
# RECOMMENDED
# ==============================================================================

# Working directory where Claude runs (loads CLAUDE.md, skills, MCP config)
CLAUDE_WORKING_DIR=/Users/yourname/personal

# OpenAI API key for voice message transcription
# Without this, voice messages won't work
OPENAI_API_KEY=sk-...

# DeepSeek API key — single shared key for all DeepSeek-routed guests.
# Guests using DeepSeek (all new guests except Ksenia) will use this key.
# Get from: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-...

# Composio API key for Google Workspace MCP (managed OAuth).
# Gives guests access to Google Docs/Drive/Sheets/Gmail/Calendar via /google command.
# Get from: https://app.composio.dev/developers
# COMPOSIO_API_KEY=

# ==============================================================================
# OPTIONAL - Security
# ==============================================================================

# Comma-separated paths Claude can access
# Default: working dir, ~/Documents, ~/Downloads, ~/Desktop, ~/.claude
# Note: Setting this OVERRIDES defaults. Include ~/.claude for plan mode to work.
# On a server include /var/log so the bot can read its own logs from inside chat.
# ALLOWED_PATHS=/Users/yourname/personal,/Users/yourname/projects,/Users/yourname/.claude
# Server example:
# ALLOWED_PATHS=/opt,/root,/home,/tmp,/var/tmp,/usr/local,/etc,/var/log

# Rate limiting (token bucket)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# ==============================================================================
# OPTIONAL - Claude Authentication
# ==============================================================================

# API key for environments without Claude Code CLI auth
# Get from: https://console.anthropic.com/
# Note: API usage is billed per token - CLI auth is more cost-effective
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Path to Claude CLI (auto-detected from PATH by default)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# ==============================================================================
# OPTIONAL - Extended Thinking
# ==============================================================================

# Keywords that trigger extended thinking (comma-separated, case-insensitive)
# THINKING_KEYWORDS=think,pensa,ragiona

# Keywords that trigger deep thinking (50k tokens)
# THINKING_DEEP_KEYWORDS=ultrathink,think hard,pensa bene

# ==============================================================================
# OPTIONAL - Voice Transcription
# ==============================================================================

# Path to a text file with additional context for voice transcription
# (names, technical terms, etc. — keeps personal context outside this repo)
# TRANSCRIPTION_CONTEXT_FILE=/path/to/transcription-context.txt

# ==============================================================================
# OPTIONAL - Dashboard URL
# ==============================================================================
# Public origin of the Mini App / landing. Each bot must point at a dashboard
# served by *its own* host — initData is HMAC-signed with the bot's token, so
# prod's dashboard rejects test-bot users and vice versa.
# Default: https://proboi.site (production). For jinru/@ORCH7_bot use the
# test host's domain (whichever proxies port 3848 there).
# DASHBOARD_URL=https://proboi.site

# ==============================================================================
# OPTIONAL - Logging
# ==============================================================================

# Audit log path
# AUDIT_LOG_PATH=/tmp/claude-telegram-audit.log

# Output audit logs as JSON (default: human-readable)
# AUDIT_LOG_JSON=false

# ==============================================================================
# OPTIONAL - YuKassa Payments
# ==============================================================================

YUKASSA_SHOP_ID=        # ID магазина из личного кабинета YuKassa (числовой)
YUKASSA_SECRET_KEY=     # Секретный ключ (test_... или live_...)
YUKASSA_WEBHOOK_SECRET= # Произвольная строка для верификации вебхука
FREE_DAILY_LIMIT=10     # Дневной лимит сообщений для бесплатного тарифа

# ==============================================================================
# OPTIONAL - RF-DB user-db microservice (242-ФЗ personal data localization)
# ==============================================================================
# When set, bot routes user/metering/consent data to the user-db HTTP service.
# Leave empty to use local fs/SQLite (default for local dev and jinru).
# USER_DB_URL=http://127.0.0.1:3900
# USER_DB_TOKEN=changeme-32-chars-random-secret

# ==============================================================================
# OPTIONAL - OpenRouter per-user subkeys
# ==============================================================================

