FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl wget git ca-certificates \
    build-essential python3 python3-pip python3-venv python-is-python3 \
    unzip sqlite3 nginx \
    openssh-client rsync jq \
    nano vim-tiny less htop \
    iputils-ping \
    procps lsof \
    && rm -rf /var/lib/apt/lists/*

# Document tooling — PDF, Excel, PPTX, видео, OCR
# Размер: +800MB (libreoffice ~400MB, ffmpeg ~150MB, pandoc ~150MB).
# Без этого набора каждое первое использование тратит 30-90с на apt install.
RUN apt-get update && apt-get install -y --no-install-recommends \
    poppler-utils \
    pandoc \
    wkhtmltopdf \
    libreoffice-impress libreoffice-calc libreoffice-writer \
    imagemagick \
    ffmpeg \
    tesseract-ocr tesseract-ocr-rus tesseract-ocr-eng \
    fonts-liberation fonts-dejavu fonts-noto-core \
    && rm -rf /var/lib/apt/lists/*

# ImageMagick: отключаем опасные кодеки (RCE через специально сформированный SVG/MVG/EPS).
# Известная атаковая поверхность с CVE-2016-3714 ("ImageTragick") и последующими.
# Гость работает с любыми input-файлами, поэтому ужесточаем policy.
RUN POLICY=/etc/ImageMagick-6/policy.xml; \
    if [ -f "$POLICY" ]; then \
        for p in URL HTTPS MVG MSL TEXT SHOW WIN PLT PS PS2 PS3 EPS PDF XPS LABEL SVG; do \
            grep -q "pattern=\"$p\"" "$POLICY" || \
            sed -i "/<\/policymap>/i\\  <policy domain=\"coder\" rights=\"none\" pattern=\"$p\" />" "$POLICY"; \
        done; \
    fi

# Python data/doc stack — самые частые библиотеки для отчётов и обработки
RUN pip3 install --no-cache-dir --break-system-packages \
    openpyxl pandas numpy \
    python-pptx python-docx \
    pillow reportlab pypdf2 pdfplumber \
    requests beautifulsoup4 lxml \
    matplotlib \
    yt-dlp

# Bun installs to /usr/local so the sandbox user (uid=1000) can use it.
# Default install location is $HOME/.bun — that lands in /root/.bun, which
# is mode 0700 and unreachable for non-root users.
# V-30G: pinned version prevents silent upgrades from breaking sandbox.
# To update: bump BUN_VERSION, verify sha256 from https://github.com/oven-sh/bun/releases
# TODO V-30G: add --checksums sha256:<hash> once Bun installer supports it natively.
ARG BUN_VERSION=1.3.13
ENV BUN_INSTALL=/usr/local
RUN curl -fsSL https://bun.sh/install | bash -s "bun-v${BUN_VERSION}"
ENV PATH="/usr/local/bin:$PATH"

# Node.js 20 LTS — pinned to major via nodesource setup script.
# V-30G: nodesource setup_20.x pins to Node 20.x LTS; no curl-pipe for the
# actual binary (apt handles verification via nodesource GPG key).
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Global tools (land in /usr/local/bin via BUN_INSTALL)
RUN bun install -g typescript tsx pnpm

# nginx default config для пользовательских сайтов
RUN echo 'server { listen 80; root /workspace/public; index index.html; location / { try_files $uri $uri/ =404; } }' \
    > /etc/nginx/sites-available/default

# Pre-create dropbox mount point (bind-mounts will replace it, but having
# the dir guarantees consistent behavior across Docker versions).
RUN mkdir -p /tmp/dropbox

COPY scripts/daemon-runner/daemon-runner /usr/local/bin/daemon-runner
RUN chmod +x /usr/local/bin/daemon-runner

COPY scripts/scheduler/scheduler /usr/local/bin/bot-scheduler
RUN chmod +x /usr/local/bin/bot-scheduler

# Non-root sandbox user for guest containers. uid/gid 1000 must match the
# values manager.ts uses when chown'ing the bind-mounted vault/dropbox on
# the host — otherwise the sandbox user can't write to its own workdir.
# Owner containers override this with --user=root via spec.ts.
RUN groupadd -g 1000 sandbox \
    && useradd -m -u 1000 -g 1000 -s /bin/bash sandbox \
    && mkdir -p /workspace \
    && chown sandbox:sandbox /workspace

WORKDIR /workspace
USER sandbox

CMD ["/usr/local/bin/daemon-runner"]
